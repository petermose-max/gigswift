# GigSwift Agent — environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored.
# Every variable below maps to a field in app/core/config.py (Pydantic Settings).

# ---------------------------------------------------------------------------
# Database
# Auto-set by docker-compose; override only for GitHub Actions / local runs.
# Format: postgresql+asyncpg://<user>:<password>@<host>:5432/<db>
# ---------------------------------------------------------------------------
DATABASE_URL=

# ---------------------------------------------------------------------------
# X (Twitter) — from developer.twitter.com, free tier write access
# ---------------------------------------------------------------------------
X_API_KEY=                      # API key (consumer key)
X_API_SECRET=                   # API secret (consumer secret)
X_ACCESS_TOKEN=                 # access token for the posting account
X_ACCESS_SECRET=                # access token secret

# ---------------------------------------------------------------------------
# Telegram Bot — from @BotFather, used to POST to the channel
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=             # bot token, e.g. 123456:ABC-DEF...
TELEGRAM_CHANNEL_ID=            # @gigswift_jobs or numeric -100xxxxxxxxxx

# ---------------------------------------------------------------------------
# Telegram Client (Telethon) — from my.telegram.org, used to READ channels
# ---------------------------------------------------------------------------
TELEGRAM_API_ID=                # integer app id
TELEGRAM_API_HASH=              # app hash string

# ---------------------------------------------------------------------------
# Pipeline config (have defaults in config.py; leave blank to use defaults)
# ---------------------------------------------------------------------------
MIN_SCORE_THRESHOLD=            # min score 0.0–1.0 to post (default 0.5)
MIN_PAY_HOURLY=                 # min hourly pay to favour in scoring (default 15.0)
SCHEDULER_INTERVAL_MINUTES=     # minutes between pipeline runs (default 30)
MAX_POSTS_PER_RUN=              # cap on posts per run (default 5)

# ---------------------------------------------------------------------------
# Sources
# ---------------------------------------------------------------------------
RSS_FEED_URLS=                  # comma-separated RSS feed URLs
TELEGRAM_CHANNELS=              # comma-separated channels, e.g. @remotejobshq,@onlinejobskenya

# ---------------------------------------------------------------------------
# Docker (interpolated into docker-compose.yml)
# ---------------------------------------------------------------------------
DB_PASSWORD=                    # Postgres password; for local dev use: devpassword
GITHUB_USERNAME=                # GHCR owner for the image: ghcr.io/<user>/gigswift
